# ──────────────────────────────────────────────────────────────────
# .env.example — Environment variable template
# ──────────────────────────────────────────────────────────────────
#
# HOW TO USE:
#   1. Copy this file:   copy .env.example .env   (Windows)
#                        cp  .env.example .env    (Mac/Linux)
#   2. Replace the placeholder values with your real credentials.
#   3. NEVER commit the .env file to version control.
#      It is already listed in .gitignore.
#
# ──────────────────────────────────────────────────────────────────


# ── OpenAI ────────────────────────────────────────────────────────
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-your-api-key-here

# The model to use. Options:
#   gpt-4o-mini  (fast, cheap — recommended for development)
#   gpt-4o       (most capable GPT-4 class model)
#   gpt-4-turbo  (high performance, large context)
#   gpt-3.5-turbo (legacy, very cheap)
OPENAI_MODEL=gpt-4o-mini


# ── Server ────────────────────────────────────────────────────────
# The host and port that Uvicorn will listen on.
# Defaults used if not set: 127.0.0.1:8000
HOST=127.0.0.1
PORT=8000
